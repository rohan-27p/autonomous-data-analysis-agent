AUTODATA_ENV=development
AUTODATA_STORAGE_DIR=data/runtime
AUTODATA_UPLOAD_DIR=data/uploads
AUTODATA_OLLAMA_BASE_URL=https://ollama.com
AUTODATA_OLLAMA_API_KEY=replace-with-your-ollama-api-key
